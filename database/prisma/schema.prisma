generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String        @id @default(cuid())
  githubId   String        @unique
  username   String
  avatar     String?
  email      String?       @unique
  createdAt  DateTime      @default(now())
  repositories Repository[]
  projects   Project[]
  history    AIToolHistory[]
  settings   Settings?
}

model Repository {
  id          String   @id @default(cuid())
  userId      String
  repoName    String
  description String?
  language    String?
  stars       Int      @default(0)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                  String   @id @default(cuid())
  userId              String
  name                String
  techStack           String
  architectureSummary String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIToolHistory {
  id             String   @id @default(cuid())
  userId         String
  toolUsed       String
  inputPrompt    String
  outputResponse String
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id                String @id @default(cuid())
  userId            String @unique
  theme             String @default("dark")
  aiModelPreference String @default("gpt-4.1")
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
